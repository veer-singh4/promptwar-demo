# --- GOOGLE SERVICES ---
# Get your Gemini API key from https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Get your Google Maps JS API key from https://console.cloud.google.com/
# Ensure "Maps JavaScript API" and "Places API" are enabled.
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# (Optional) Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX)
VITE_GA4_ID=G-XXXXXXXXXX

# --- APPLICATION SETTINGS ---
VITE_APP_NAME=VenueIQ Pro
VITE_ENV=development
